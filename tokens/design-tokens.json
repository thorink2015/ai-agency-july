{
  "$schema": "https://raw.githubusercontent.com/design-tokens/community-group/main/technical-reports/format/schema.json",
  "$meta": {
    "name": "AI Appointment Agency — Design Tokens",
    "version": "1.0.0",
    "description": "Single source of truth for all design decisions. All colour pairings are WCAG 2.2 contrast-validated (see docs/accessibility/contrast-matrix.md). Do not hardcode values in code — consume these tokens (tokens.css / tailwind.tokens.js).",
    "status": "v1 foundation — brand name is a placeholder ({{BRAND_NAME}}); values are production-ready and adjustable.",
    "contrastValidated": true,
    "lastValidated": "2026-07-01"
  },

  "color": {
    "brand": {
      "50":  { "value": "#EEF2FF", "type": "color", "comment": "tint background, hover states on light" },
      "100": { "value": "#E0E7FF", "type": "color" },
      "200": { "value": "#C7D2FE", "type": "color" },
      "300": { "value": "#A5B4FC", "type": "color", "comment": "brand accent text on dark (9.45:1 on ink)" },
      "400": { "value": "#818CF8", "type": "color" },
      "500": { "value": "#6366F1", "type": "color" },
      "600": { "value": "#4F46E5", "type": "color", "comment": "PRIMARY. White text = 6.29:1 AA. Default CTA / brand." },
      "700": { "value": "#4338CA", "type": "color", "comment": "primary hover/active. White text = 7.90:1 AAA." },
      "800": { "value": "#3730A3", "type": "color" },
      "900": { "value": "#312E81", "type": "color" }
    },
    "accent": {
      "400": { "value": "#22D3EE", "type": "color", "comment": "teal — decorative/highlight only" },
      "500": { "value": "#06B6D4", "type": "color", "comment": "ACCENT. Use INK text (7.76:1), NEVER white (2.43:1 FAILS)." },
      "600": { "value": "#0891B2", "type": "color" },
      "700": { "value": "#0E7490", "type": "color", "comment": "use this for white-text teal buttons (5.36:1 AA)" }
    },
    "neutral": {
      "0":   { "value": "#FFFFFF", "type": "color" },
      "50":  { "value": "#F8FAFC", "type": "color" },
      "100": { "value": "#F1F5F9", "type": "color" },
      "200": { "value": "#E2E8F0", "type": "color", "comment": "decorative divider only (1.23:1 — not a meaningful border)" },
      "300": { "value": "#CBD5E1", "type": "color", "comment": "decorative divider only" },
      "400": { "value": "#94A3B8", "type": "color", "comment": "disabled/hint ONLY (2.56:1 — never meaningful text)" },
      "500": { "value": "#64748B", "type": "color", "comment": "min muted text on white (4.76:1 AA); min interactive border (3:1)" },
      "600": { "value": "#475569", "type": "color", "comment": "secondary text (7.58:1 AAA)" },
      "700": { "value": "#334155", "type": "color", "comment": "body text (10.35:1 AAA)" },
      "800": { "value": "#1E293B", "type": "color" },
      "900": { "value": "#0F172A", "type": "color", "comment": "headings (17.85:1 AAA)" },
      "ink": { "value": "#0B1120", "type": "color", "comment": "primary text / dark sections (18.83:1 AAA)" }
    },
    "semantic": {
      "success":     { "value": "#16A34A", "type": "color", "comment": "large text/UI only with white; use success-strong for normal white text" },
      "successStrong": { "value": "#15803D", "type": "color", "comment": "white text = 5.02:1 AA" },
      "warning":     { "value": "#D97706", "type": "color", "comment": "use INK text (5.91:1); white FAILS normal text (3.19:1)" },
      "danger":      { "value": "#DC2626", "type": "color", "comment": "white text = 4.83:1 AA" },
      "info":        { "value": "#2563EB", "type": "color", "comment": "white text = 5.17:1 AA" }
    },
    "role": {
      "text":            { "value": "{color.neutral.ink}", "type": "color" },
      "textSecondary":   { "value": "{color.neutral.600}", "type": "color" },
      "textMuted":       { "value": "{color.neutral.500}", "type": "color" },
      "textOnDark":      { "value": "{color.neutral.0}", "type": "color" },
      "textMutedOnDark": { "value": "{color.neutral.300}", "type": "color" },
      "link":            { "value": "{color.brand.600}", "type": "color" },
      "linkHover":       { "value": "{color.brand.700}", "type": "color" },
      "bg":              { "value": "{color.neutral.0}", "type": "color" },
      "bgSubtle":        { "value": "{color.neutral.50}", "type": "color" },
      "bgDark":          { "value": "{color.neutral.ink}", "type": "color" },
      "border":          { "value": "{color.neutral.200}", "type": "color", "comment": "decorative" },
      "borderInteractive": { "value": "{color.neutral.500}", "type": "color", "comment": "inputs/controls, 3:1" },
      "focusRing":       { "value": "{color.brand.600}", "type": "color", "comment": "3:1 vs adjacent; pair with offset" },
      "ctaBg":           { "value": "{color.brand.600}", "type": "color" },
      "ctaBgHover":      { "value": "{color.brand.700}", "type": "color" },
      "ctaText":         { "value": "{color.neutral.0}", "type": "color" }
    }
  },

  "typography": {
    "fontFamily": {
      "display": { "value": "'Sora', 'Sora Fallback', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif", "type": "fontFamily", "comment": "headings — variable, geometric, modern-tech" },
      "body":    { "value": "'Inter', 'Inter Fallback', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif", "type": "fontFamily", "comment": "body/UI — variable, best-in-class legibility" },
      "mono":    { "value": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace", "type": "fontFamily", "comment": "code / technical accents, optional" }
    },
    "fontWeight": {
      "regular":  { "value": "400", "type": "fontWeight" },
      "medium":   { "value": "500", "type": "fontWeight" },
      "semibold": { "value": "600", "type": "fontWeight" },
      "bold":     { "value": "700", "type": "fontWeight" }
    },
    "fontSize": {
      "xs":   { "value": "0.75rem",  "type": "dimension", "comment": "12px" },
      "sm":   { "value": "0.875rem", "type": "dimension", "comment": "14px" },
      "base": { "value": "1rem",     "type": "dimension", "comment": "16px — never smaller for body" },
      "lg":   { "value": "1.125rem", "type": "dimension", "comment": "18px" },
      "xl":   { "value": "1.25rem",  "type": "dimension", "comment": "20px" },
      "2xl":  { "value": "1.5rem",   "type": "dimension", "comment": "24px" },
      "3xl":  { "value": "1.875rem", "type": "dimension", "comment": "30px" },
      "4xl":  { "value": "2.25rem",  "type": "dimension", "comment": "36px" },
      "5xl":  { "value": "3rem",     "type": "dimension", "comment": "48px" },
      "6xl":  { "value": "3.75rem",  "type": "dimension", "comment": "60px" },
      "7xl":  { "value": "4.5rem",   "type": "dimension", "comment": "72px" }
    },
    "fluid": {
      "h1": { "value": "clamp(2.25rem, 1.4rem + 4.25vw, 4.5rem)", "type": "dimension" },
      "h2": { "value": "clamp(1.875rem, 1.3rem + 2.9vw, 3rem)", "type": "dimension" },
      "h3": { "value": "clamp(1.5rem, 1.2rem + 1.5vw, 2.25rem)", "type": "dimension" },
      "lead": { "value": "clamp(1.125rem, 1.05rem + 0.4vw, 1.375rem)", "type": "dimension" }
    },
    "lineHeight": {
      "tight":   { "value": "1.1",  "type": "number", "comment": "display headings" },
      "snug":    { "value": "1.25", "type": "number" },
      "normal":  { "value": "1.5",  "type": "number", "comment": "body — min 1.5 for WCAG readability" },
      "relaxed": { "value": "1.65", "type": "number", "comment": "long-form prose" }
    },
    "letterSpacing": {
      "tighter": { "value": "-0.02em", "type": "dimension", "comment": "large display" },
      "tight":   { "value": "-0.01em", "type": "dimension" },
      "normal":  { "value": "0em",     "type": "dimension" },
      "wide":    { "value": "0.02em",  "type": "dimension", "comment": "eyebrows/labels uppercase" }
    },
    "measure": {
      "prose": { "value": "68ch", "type": "dimension", "comment": "max line length for readability (45-75ch)" }
    }
  },

  "space": {
    "0": { "value": "0",       "type": "dimension" },
    "1": { "value": "0.25rem", "type": "dimension", "comment": "4px" },
    "2": { "value": "0.5rem",  "type": "dimension", "comment": "8px" },
    "3": { "value": "0.75rem", "type": "dimension", "comment": "12px" },
    "4": { "value": "1rem",    "type": "dimension", "comment": "16px" },
    "5": { "value": "1.25rem", "type": "dimension", "comment": "20px" },
    "6": { "value": "1.5rem",  "type": "dimension", "comment": "24px" },
    "8": { "value": "2rem",    "type": "dimension", "comment": "32px" },
    "10": { "value": "2.5rem", "type": "dimension", "comment": "40px" },
    "12": { "value": "3rem",   "type": "dimension", "comment": "48px" },
    "16": { "value": "4rem",   "type": "dimension", "comment": "64px" },
    "20": { "value": "5rem",   "type": "dimension", "comment": "80px" },
    "24": { "value": "6rem",   "type": "dimension", "comment": "96px" },
    "32": { "value": "8rem",   "type": "dimension", "comment": "128px — section rhythm" }
  },

  "radius": {
    "sm":   { "value": "0.375rem", "type": "dimension", "comment": "6px" },
    "md":   { "value": "0.5rem",   "type": "dimension", "comment": "8px — default control" },
    "lg":   { "value": "0.75rem",  "type": "dimension", "comment": "12px — cards" },
    "xl":   { "value": "1rem",     "type": "dimension", "comment": "16px" },
    "2xl":  { "value": "1.5rem",   "type": "dimension", "comment": "24px — hero panels" },
    "full": { "value": "9999px",   "type": "dimension", "comment": "pills / avatars" }
  },

  "shadow": {
    "xs": { "value": "0 1px 2px 0 rgb(11 17 32 / 0.05)", "type": "shadow" },
    "sm": { "value": "0 1px 3px 0 rgb(11 17 32 / 0.08), 0 1px 2px -1px rgb(11 17 32 / 0.08)", "type": "shadow" },
    "md": { "value": "0 4px 6px -1px rgb(11 17 32 / 0.08), 0 2px 4px -2px rgb(11 17 32 / 0.08)", "type": "shadow" },
    "lg": { "value": "0 10px 15px -3px rgb(11 17 32 / 0.10), 0 4px 6px -4px rgb(11 17 32 / 0.10)", "type": "shadow" },
    "xl": { "value": "0 20px 25px -5px rgb(11 17 32 / 0.12), 0 8px 10px -6px rgb(11 17 32 / 0.12)", "type": "shadow" },
    "focus": { "value": "0 0 0 3px rgb(79 70 229 / 0.45)", "type": "shadow", "comment": "focus-visible ring" }
  },

  "breakpoint": {
    "sm": { "value": "640px",  "type": "dimension", "comment": "large phone / small tablet" },
    "md": { "value": "768px",  "type": "dimension", "comment": "tablet portrait" },
    "lg": { "value": "1024px", "type": "dimension", "comment": "tablet landscape / small laptop" },
    "xl": { "value": "1280px", "type": "dimension", "comment": "desktop" },
    "2xl": { "value": "1536px", "type": "dimension", "comment": "large desktop" }
  },

  "container": {
    "prose":  { "value": "68ch",   "type": "dimension" },
    "content": { "value": "1200px", "type": "dimension", "comment": "max content width" },
    "wide":   { "value": "1440px",  "type": "dimension" },
    "gutter": { "value": "clamp(1rem, 5vw, 2rem)", "type": "dimension", "comment": "page side padding" }
  },

  "zIndex": {
    "base":    { "value": "0",   "type": "number" },
    "dropdown": { "value": "1000", "type": "number" },
    "sticky":  { "value": "1100", "type": "number" },
    "overlay": { "value": "1200", "type": "number" },
    "modal":   { "value": "1300", "type": "number" },
    "toast":   { "value": "1400", "type": "number" },
    "tooltip": { "value": "1500", "type": "number" }
  },

  "motion": {
    "duration": {
      "instant": { "value": "100ms", "type": "duration" },
      "fast":    { "value": "150ms", "type": "duration", "comment": "hovers, small state" },
      "base":    { "value": "200ms", "type": "duration" },
      "slow":    { "value": "300ms", "type": "duration", "comment": "enter/exit" },
      "slower":  { "value": "500ms", "type": "duration", "comment": "large transitions" }
    },
    "easing": {
      "standard":  { "value": "cubic-bezier(0.4, 0, 0.2, 1)", "type": "cubicBezier" },
      "decelerate": { "value": "cubic-bezier(0, 0, 0.2, 1)",  "type": "cubicBezier", "comment": "entering" },
      "accelerate": { "value": "cubic-bezier(0.4, 0, 1, 1)",  "type": "cubicBezier", "comment": "exiting" },
      "spring":    { "value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "type": "cubicBezier", "comment": "playful overshoot — use sparingly" }
    },
    "reducedMotion": { "value": "All non-essential motion MUST be gated behind @media (prefers-reduced-motion: no-preference). Provide instant/opacity-only fallbacks.", "type": "note" }
  },

  "opacity": {
    "disabled": { "value": "0.5", "type": "number" },
    "muted":    { "value": "0.7", "type": "number" },
    "backdrop": { "value": "0.6", "type": "number" }
  },

  "target": {
    "minTouch": { "value": "44px", "type": "dimension", "comment": "WCAG 2.5.8 min 24px; we require 44px comfortable target, 8px min spacing" },
    "minTouchSpacing": { "value": "8px", "type": "dimension" }
  }
}
