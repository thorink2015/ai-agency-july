          "price": "{{MONTHLY_PRICE}}",
          "priceCurrency": "USD",
          "unitText": "MONTH",
          "billingIncrement": 1
        },
        "availability": "https://schema.org/InStock",
        "url": "https://{{DOMAIN}}/pricing/",
        "category": "Subscription"
      }
    ]
  },
